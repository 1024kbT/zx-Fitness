.tabbar {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  padding: 16rpx 8rpx calc(12rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(15, 16, 20, 0.6) 0%, #0F1014 40%);
  backdrop-filter: blur(24px);
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
  position: relative;
  height: 112rpx;
  box-sizing: content-box;
}

.tabbar__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
  padding: 4rpx 0;
}

/* 图标外圈容器 */
.tabbar__icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}
.tabbar__icon-wrap--active {
  background: #80FF00;
  box-shadow: 0 0 20rpx rgba(128, 255, 0, 0.5);
}

/* 图标本体（默认灰色，选中时白色） */
.tabbar__icon {
  position: relative;
  width: 32rpx;
  height: 32rpx;
  background-color: #5A5C66;
  -webkit-mask-size: contain;
  mask-size: contain;
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-position: center;
  mask-position: center;
}
.tabbar__item--active .tabbar__icon {
  background-color: #0F1014;
}

/* 文本 */
.tabbar__text {
  font-size: 20rpx;
  color: #5A5C66;
  letter-spacing: 0.3rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 120rpx;
  line-height: 1.2;
}
.tabbar__item--active .tabbar__text {
  color: #80FF00;
  font-weight: 600;
}

/* ===== 图标样式（用 SVG mask 或纯 CSS） ===== */

/* 1. 网格 (数据看板) - 九宫格 */
.tabbar__icon--grid {
  background-image:
    radial-gradient(circle at 20% 20%, currentColor 0, currentColor 18%, transparent 19%),
    radial-gradient(circle at 50% 20%, currentColor 0, currentColor 18%, transparent 19%),
    radial-gradient(circle at 80% 20%, currentColor 0, currentColor 18%, transparent 19%),
    radial-gradient(circle at 20% 50%, currentColor 0, currentColor 18%, transparent 19%),
    radial-gradient(circle at 50% 50%, currentColor 0, currentColor 18%, transparent 19%),
    radial-gradient(circle at 80% 50%, currentColor 0, currentColor 18%, transparent 19%),
    radial-gradient(circle at 20% 80%, currentColor 0, currentColor 18%, transparent 19%),
    radial-gradient(circle at 50% 80%, currentColor 0, currentColor 18%, transparent 19%),
    radial-gradient(circle at 80% 80%, currentColor 0, currentColor 18%, transparent 19%);
  background-color: transparent !important;
}
.tabbar__icon--grid::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 20% 20%, #5A5C66 0, #5A5C66 18%, transparent 19%),
    radial-gradient(circle at 50% 20%, #5A5C66 0, #5A5C66 18%, transparent 19%),
    radial-gradient(circle at 80% 20%, #5A5C66 0, #5A5C66 18%, transparent 19%),
    radial-gradient(circle at 20% 50%, #5A5C66 0, #5A5C66 18%, transparent 19%),
    radial-gradient(circle at 50% 50%, #5A5C66 0, #5A5C66 18%, transparent 19%),
    radial-gradient(circle at 80% 50%, #5A5C66 0, #5A5C66 18%, transparent 19%),
    radial-gradient(circle at 20% 80%, #5A5C66 0, #5A5C66 18%, transparent 19%),
    radial-gradient(circle at 50% 80%, #5A5C66 0, #5A5C66 18%, transparent 19%),
    radial-gradient(circle at 80% 80%, #5A5C66 0, #5A5C66 18%, transparent 19%);
}
.tabbar__item--active .tabbar__icon--grid::before {
  background:
    radial-gradient(circle at 20% 20%, #0F1014 0, #0F1014 18%, transparent 19%),
    radial-gradient(circle at 50% 20%, #0F1014 0, #0F1014 18%, transparent 19%),
    radial-gradient(circle at 80% 20%, #0F1014 0, #0F1014 18%, transparent 19%),
    radial-gradient(circle at 20% 50%, #0F1014 0, #0F1014 18%, transparent 19%),
    radial-gradient(circle at 50% 50%, #0F1014 0, #0F1014 18%, transparent 19%),
    radial-gradient(circle at 80% 50%, #0F1014 0, #0F1014 18%, transparent 19%),
    radial-gradient(circle at 20% 80%, #0F1014 0, #0F1014 18%, transparent 19%),
    radial-gradient(circle at 50% 80%, #0F1014 0, #0F1014 18%, transparent 19%),
    radial-gradient(circle at 80% 80%, #0F1014 0, #0F1014 18%, transparent 19%);
}

/* 2. 双链环 (训练日程) */
.tabbar__icon--chain {
  background-color: transparent !important;
}
.tabbar__icon--chain::before,
.tabbar__icon--chain::after {
  content: '';
  position: absolute;
  width: 22rpx;
  height: 18rpx;
  border: 3rpx solid #5A5C66;
  border-radius: 9rpx;
  top: 50%;
  transform: translateY(-50%);
}
.tabbar__icon--chain::before { left: 0; }
.tabbar__icon--chain::after  { right: 0; }
.tabbar__item--active .tabbar__icon--chain::before,
.tabbar__item--active .tabbar__icon--chain::after {
  border-color: #0F1014;
}

/* 3. 苹果 (饮食计划) */
.tabbar__icon--apple {
  width: 28rpx;
  height: 30rpx;
  background-color: transparent !important;
  position: relative;
}
.tabbar__icon--apple::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 26rpx;
  height: 26rpx;
  border-radius: 50% 50% 45% 45%;
  background: #5A5C66;
}
.tabbar__icon--apple::after {
  content: '';
  position: absolute;
  top: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 6rpx;
  height: 8rpx;
  background: #5A5C66;
  border-radius: 2rpx 2rpx 0 0;
}
.tabbar__item--active .tabbar__icon--apple::before,
.tabbar__item--active .tabbar__icon--apple::after {
  background: #0F1014;
}

/* 4. 折线图 (身体数据) */
.tabbar__icon--line {
  background-color: transparent !important;
}
.tabbar__icon--line::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to right, transparent 0, transparent 15%, #5A5C66 15%, #5A5C66 17%, transparent 17%, transparent 100%) top left / 100% 100% no-repeat,
    linear-gradient(to top, transparent 0, transparent 15%, #5A5C66 15%, #5A5C66 17%, transparent 17%, transparent 100%) top left / 100% 100% no-repeat;
}
.tabbar__icon--line::after {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 6rpx;
  width: 22rpx;
  height: 16rpx;
  background: linear-gradient(135deg, transparent 45%, #5A5C66 45%, #5A5C66 55%, transparent 55%);
}
.tabbar__item--active .tabbar__icon--line::before {
  background:
    linear-gradient(to right, transparent 0, transparent 15%, #0F1014 15%, #0F1014 17%, transparent 17%, transparent 100%) top left / 100% 100% no-repeat,
    linear-gradient(to top, transparent 0, transparent 15%, #0F1014 15%, #0F1014 17%, transparent 17%, transparent 100%) top left / 100% 100% no-repeat;
}
.tabbar__item--active .tabbar__icon--line::after {
  background: linear-gradient(135deg, transparent 45%, #0F1014 45%, #0F1014 55%, transparent 55%);
}

/* 5. 心电图 (运动记录) */
.tabbar__icon--pulse {
  background-color: transparent !important;
  height: 24rpx;
  margin-top: 4rpx;
}
.tabbar__icon--pulse::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to right,
      transparent 0, transparent 10%,
      #5A5C66 10%, #5A5C66 13%, transparent 13%, transparent 25%,
      #5A5C66 25%, #5A5C66 28%, transparent 28%, transparent 40%,
      #5A5C66 40%, #5A5C66 43%, transparent 43%, transparent 100%
    );
  clip-path: polygon(
    0% 50%,
    10% 50%,
    15% 20%,
    20% 80%,
    25% 10%,
    30% 90%,
    35% 30%,
    40% 50%,
    100% 50%,
    100% 55%,
    40% 55%,
    35% 35%,
    30% 95%,
    25% 15%,
    20% 85%,
    15% 25%,
    10% 55%,
    0% 55%
  );
  background: #5A5C66;
}
.tabbar__item--active .tabbar__icon--pulse::before {
  background: #0F1014;
}

/* ===== 训练日程 ===== */

.sch-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 4rpx 24rpx;
}
.sch-header__brand {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.sch-header__logo {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: rgba(128, 255, 0, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}
.sch-header__title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-v1);
  letter-spacing: 0.5rpx;
}
.sch-header__action {
  font-size: 22rpx;
  color: var(--accent-v2);
  font-weight: 500;
}

/* 复用 dashboard 的 header__bell */
.header__bell {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--bg-card-v2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.header__bell-icon { font-size: 32rpx; }
.header__bell:active { background: var(--bg-elevated); }

/* 统计 3 列 */
.stat-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}
.stat-card {
  background: var(--bg-card-v2);
  border-radius: var(--radius-md);
  padding: 22rpx 18rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.stat-card__label {
  font-size: 20rpx;
  color: var(--text-v2);
  letter-spacing: 0.3rpx;
}
.stat-card__value {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.stat-card__num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-v1);
  font-variant-numeric: tabular-nums;
  line-height: 1;
  letter-spacing: -1rpx;
}
.stat-card__num--accent { color: var(--accent-v2); }
.stat-card__unit {
  font-size: 18rpx;
  color: var(--text-v2);
  font-weight: 400;
}

/* 周切换 */
.week-nav {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0 20rpx;
}
.week-nav__btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--bg-card-v2);
  text-align: center;
  line-height: 56rpx;
  font-size: 32rpx;
  color: var(--text-v1);
  flex-shrink: 0;
}
.week-nav__btn:active { background: var(--bg-elevated); }
.week-nav__title {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-v1);
  letter-spacing: 0.5rpx;
}
.week-nav__today {
  padding: 10rpx 20rpx;
  background: rgba(128, 255, 0, 0.12);
  color: var(--accent-v2);
  border: 1rpx solid rgba(128, 255, 0, 0.3);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  white-space: nowrap;
}
.week-nav__today:active { background: rgba(128, 255, 0, 0.2); }

/* 日程列表 */
.day-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.day-item {
  background: var(--bg-card-v2);
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 1rpx solid transparent;
}
.day-item--today {
  border-color: rgba(128, 255, 0, 0.25);
  box-shadow: 0 0 20rpx rgba(128, 255, 0, 0.1);
}
.day-item__head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx;
  position: relative;
}
.day-item__date {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  flex-shrink: 0;
}
.day-item__dow {
  font-size: 22rpx;
  color: var(--text-v2);
  letter-spacing: 0.3rpx;
}
.day-item__md {
  font-size: 24rpx;
  color: var(--text-v1);
  font-weight: 600;
  font-variant-numeric: tabular-nums;
  margin-top: 4rpx;
}
.day-item--today .day-item__dow { color: var(--accent-v2); }
.day-item--today .day-item__md { color: var(--accent-v2); }

.day-item__icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.day-item__icon--done {
  background: var(--accent-v2);
  color: #0F1014;
}
.day-item__icon--plan {
  background: rgba(128, 255, 0, 0.15);
  color: var(--accent-v2);
}
.day-item__icon--rest {
  background: rgba(156, 39, 176, 0.15);
  color: var(--purple);
  font-size: 24rpx;
}
.day-item__icon--empty {
  background: rgba(255, 255, 255, 0.04);
  color: var(--text-v3);
  font-size: 24rpx;
}

.day-item__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.day-item__title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-v1);
  letter-spacing: 0.3rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.day-item__title--muted {
  color: var(--text-v2);
  font-weight: 500;
}
.day-item__sub {
  font-size: 20rpx;
  color: var(--text-v2);
  letter-spacing: 0.3rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.day-item__arrow {
  font-size: 32rpx;
  color: var(--text-v2);
  transform: rotate(90deg);
  transition: transform 0.25s ease;
  flex-shrink: 0;
}
.day-item__arrow--open {
  transform: rotate(-90deg);
}

/* 展开详情 */
.day-item__expand {
  padding: 0 22rpx 22rpx;
  animation: expandIn 0.25s ease both;
}
@keyframes expandIn {
  from { opacity: 0; max-height: 0; }
  to { opacity: 1; max-height: 800rpx; }
}

/* 动作表格 */
.day-table {
  background: var(--bg-card-2);
  border-radius: var(--radius-sm);
  overflow: hidden;
  border: 1rpx solid var(--border-v2);
  margin-bottom: 16rpx;
}
.day-table__head {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  background: #2D2E3A;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid var(--border-v2);
}
.day-table__th {
  font-size: 20rpx;
  color: var(--text-v2);
  font-weight: 600;
  letter-spacing: 0.5rpx;
  text-align: center;
}
.day-table__th--name { text-align: left; }
.day-table__row {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  padding: 14rpx 20rpx;
  border-bottom: 1rpx solid var(--border-v2);
}
.day-table__row:last-child { border-bottom: none; }
.day-table__td {
  font-size: 22rpx;
  color: var(--text-v1);
  text-align: center;
  font-variant-numeric: tabular-nums;
}
.day-table__td--name {
  text-align: left;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.day-item__summary {
  font-size: 22rpx;
  color: var(--text-v2);
  text-align: center;
  padding: 8rpx 0;
  letter-spacing: 0.3rpx;
}

.day-item__start {
  padding: 20rpx;
  background: var(--accent-v2);
  color: #0F1014;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 999rpx;
  text-align: center;
  letter-spacing: 0.5rpx;
}
.day-item__start:active { opacity: 0.85; transform: scale(0.98); }

.day-item__rest-actions {
  display: flex;
  justify-content: center;
  padding: 8rpx 0;
}

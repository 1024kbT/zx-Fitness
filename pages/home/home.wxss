.home {
  padding: 20rpx 24rpx calc(180rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  background: #0a0e17;
  box-sizing: border-box;
}

/* ===== 顶部问候 ===== */
.greet { padding: 16rpx 8rpx 24rpx; }
.greet__row { display: flex; align-items: center; gap: 16rpx; }
.greet__icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff9d5c 0%, #ff5e85 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: 0 0 20rpx rgba(255, 157, 92, 0.4);
}
.greet__body { flex: 1; }
.greet__text {
  font-size: 34rpx;
  font-weight: 700;
  color: #f0f0f5;
  margin-bottom: 4rpx;
}
.greet__sub {
  font-size: 22rpx;
  color: #8b8fa3;
  letter-spacing: 1rpx;
}

/* ===== 热量缺口卡 ===== */
.gap-card {
  padding: 32rpx 28rpx;
  background: linear-gradient(160deg, #0d2818 0%, #0a1628 60%, #0e0a28 100%);
  border: 1rpx solid rgba(0, 255, 136, 0.15);
  margin-bottom: 20rpx;
}
.gap-card__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.gap-card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #f0f0f5;
  letter-spacing: 1rpx;
}
.gap-card__sub {
  font-size: 20rpx;
  color: #8b8fa3;
  letter-spacing: 1rpx;
}

.gap-ring-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 0 32rpx;
}
.gap-ring {
  position: relative;
  width: 320rpx;
  height: 320rpx;
}
.gap-ring__fill {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  transition: background 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  filter: drop-shadow(0 0 14rpx rgba(0, 255, 136, 0.4));
}
.gap-ring__hole {
  position: absolute;
  inset: 22rpx;
  border-radius: 50%;
  background: linear-gradient(160deg, #0d2818 0%, #0a1628 60%, #0e0a28 100%);
  box-shadow: inset 0 0 16rpx rgba(0, 0, 0, 0.4);
}
.gap-ring__text {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.gap-ring__num {
  font-size: 84rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  line-height: 1;
  text-shadow: 0 0 40rpx currentColor;
}
.gap-ring__num--green { color: #00ff88; }
.gap-ring__num--red { color: #ff4d6a; }
.gap-ring__unit {
  font-size: 22rpx;
  color: #8b8fa3;
  margin-top: 8rpx;
  letter-spacing: 3rpx;
}
.gap-ring__label {
  font-size: 20rpx;
  color: #4b5563;
  margin-top: 4rpx;
  letter-spacing: 2rpx;
}

.gap-split {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.gap-item {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 16rpx 14rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: 14rpx;
  gap: 10rpx;
}
.gap-item--in { border-color: rgba(255, 157, 92, 0.25); }
.gap-item--out { border-color: rgba(0, 255, 136, 0.25); }
.gap-item__icon { font-size: 28rpx; }
.gap-item__body { flex: 1; min-width: 0; }
.gap-item__label {
  display: block;
  font-size: 20rpx;
  color: #8b8fa3;
  letter-spacing: 1rpx;
}
.gap-item__val {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #f0f0f5;
  font-variant-numeric: tabular-nums;
  line-height: 1.2;
}
.gap-item__unit {
  font-size: 18rpx;
  color: #8b8fa3;
  font-weight: 400;
  margin-left: 4rpx;
}
.gap-item__sub {
  display: block;
  font-size: 16rpx;
  color: #4b5563;
  margin-top: 2rpx;
}
.gap-item__arrow {
  font-size: 26rpx;
  color: #4b5563;
  flex-shrink: 0;
}
.gap-divider { width: 1rpx; background: rgba(255, 255, 255, 0.04); }

.gap-card__footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 8rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
  font-size: 22rpx;
  color: #8b8fa3;
}
.gap-card__edit { color: var(--primary); }

/* ===== 体重条 ===== */
.weight-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
}
.weight-bar__left { display: flex; align-items: center; gap: 16rpx; }
.weight-bar__icon {
  font-size: 32rpx;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 229, 255, 0.08);
  border-radius: 12rpx;
}
.weight-bar__label {
  font-size: 20rpx;
  color: #8b8fa3;
  letter-spacing: 1rpx;
}
.weight-bar__val {
  font-size: 34rpx;
  font-weight: 700;
  color: #f0f0f5;
  font-variant-numeric: tabular-nums;
  line-height: 1.1;
}
.weight-bar__unit {
  font-size: 20rpx;
  color: #8b8fa3;
  font-weight: 400;
  margin-left: 4rpx;
}
.weight-bar__delta {
  font-size: 22rpx;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}
.weight-bar__delta--down {
  color: #00ff88;
  background: rgba(0, 255, 136, 0.1);
  border: 1rpx solid rgba(0, 255, 136, 0.25);
}
.weight-bar__delta--up {
  color: #ff4d6a;
  background: rgba(255, 77, 106, 0.1);
  border: 1rpx solid rgba(255, 77, 106, 0.25);
}
.weight-bar__delta--flat {
  color: #8b8fa3;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}
.weight-bar__vs {
  font-size: 16rpx;
  color: #4b5563;
  margin-left: 6rpx;
  font-weight: 400;
}

/* ===== 快速入口 ===== */
.quick {
  padding: 0 8rpx 16rpx;
}
.quick__title {
  font-size: 26rpx;
  font-weight: 700;
  color: #f0f0f5;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}
.quick__grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 12rpx;
}
.quick__item {
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 18rpx 8rpx;
  text-align: center;
}
.quick__item:active { background: rgba(255, 255, 255, 0.08); }
.quick__icon {
  width: 64rpx;
  height: 64rpx;
  margin: 0 auto 10rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}
.quick__icon--diet { background: rgba(0, 255, 136, 0.1); }
.quick__icon--weight { background: rgba(0, 229, 255, 0.1); }
.quick__icon--ai { background: rgba(167, 139, 250, 0.15); }
.quick__icon--me { background: rgba(255, 157, 92, 0.12); }
.quick__name {
  font-size: 22rpx;
  color: #f0f0f5;
  font-weight: 600;
  margin-bottom: 2rpx;
}
.quick__desc {
  font-size: 16rpx;
  color: #4b5563;
}

/* ===== 本周打卡 ===== */
.checkin {
  padding: 22rpx 28rpx;
  margin-bottom: 20rpx;
}
.checkin__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.checkin__title {
  font-size: 26rpx;
  font-weight: 700;
  color: #f0f0f5;
}
.checkin__count {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}
.checkin__dots {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
}
.checkin__dot {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  position: relative;
  transition: transform 0.15s;
}
.checkin__dot:active { transform: scale(0.92); }
.checkin__label {
  font-size: 20rpx;
  color: #4b5563;
  font-weight: 500;
}
.checkin__check {
  font-size: 18rpx;
  color: transparent;
  font-weight: 700;
}
.checkin__dot--on {
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  box-shadow: 0 0 12rpx rgba(0, 255, 136, 0.3);
}
.checkin__dot--on .checkin__label { color: #0a0e17; font-weight: 700; }
.checkin__dot--on .checkin__check { color: #0a0e17; }
.checkin__dot--today {
  border: 1rpx solid rgba(0, 229, 255, 0.4);
  box-shadow: inset 0 0 0 1rpx rgba(0, 229, 255, 0.15);
}
.checkin__hint {
  margin-top: 16rpx;
  text-align: center;
  font-size: 22rpx;
  color: #ff9d5c;
  padding: 10rpx 14rpx;
  background: rgba(255, 157, 92, 0.06);
  border-radius: 10rpx;
  letter-spacing: 0.5rpx;
}

/* ===== 训练预览 ===== */
.preview {
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
}
.preview__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.preview__title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #f0f0f5;
}
.preview__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #4b5563;
}
.preview__dot--on {
  background: #00ff88;
  box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  animation: dotPulse 1.8s ease-out infinite;
}
@keyframes dotPulse {
  from { box-shadow: 0 0 0 0 rgba(0, 255, 136, 0.6); }
  to { box-shadow: 0 0 0 16rpx rgba(0, 255, 136, 0); }
}
.preview__sub {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 600;
}
.preview__tag {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 20rpx;
  color: #00e5ff;
  margin-bottom: 12rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}
.preview__muscle {
  font-size: 18rpx;
  color: #4b5563;
  font-weight: 400;
}
.preview__list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.preview__item {
  display: flex;
  align-items: center;
  padding: 14rpx 12rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  gap: 12rpx;
}
.preview__item:active { background: rgba(255, 255, 255, 0.08); }
.preview__emoji {
  font-size: 28rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 255, 136, 0.06);
  border-radius: 10rpx;
  flex-shrink: 0;
}
.preview__info { flex: 1; min-width: 0; }
.preview__name {
  display: block;
  font-size: 24rpx;
  color: #f0f0f5;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.preview__meta {
  display: block;
  font-size: 18rpx;
  color: #8b8fa3;
  font-variant-numeric: tabular-nums;
  margin-top: 2rpx;
}
.preview__arrow {
  font-size: 26rpx;
  color: #4b5563;
}
.preview__empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0 10rpx;
  gap: 12rpx;
  color: #4b5563;
  font-size: 24rpx;
}
.preview__empty-icon { font-size: 32rpx; }

/* ===== 训练入口 ===== */
.train-entry {
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
}
.train-entry__main {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 20rpx;
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.12) 0%, rgba(0, 229, 255, 0.08) 100%);
  border: 1rpx solid rgba(0, 255, 136, 0.3);
  border-radius: 18rpx;
  margin-bottom: 16rpx;
  transition: transform 0.15s;
}
.train-entry__main:active { transform: scale(0.98); }
.train-entry__main-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(0, 255, 136, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}
.train-entry__main-body { flex: 1; min-width: 0; }
.train-entry__main-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #f0f0f5;
  margin-bottom: 4rpx;
}
.train-entry__main-sub {
  font-size: 20rpx;
  color: #8b8fa3;
  letter-spacing: 0.5rpx;
}
.train-entry__main-arrow {
  font-size: 40rpx;
  color: #00ff88;
  font-weight: 300;
  flex-shrink: 0;
}
.train-entry__shortcuts {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}
.train-entry__chip {
  padding: 12rpx 18rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #8b8fa3;
  font-weight: 500;
}
.train-entry__chip:active {
  background: rgba(255, 255, 255, 0.1);
  color: #f0f0f5;
}
.train-entry__hint {
  margin-top: 16rpx;
  text-align: center;
  font-size: 22rpx;
  color: #ff9d5c;
  padding: 14rpx 16rpx;
  background: rgba(255, 157, 92, 0.08);
  border: 1rpx solid rgba(255, 157, 92, 0.2);
  border-radius: 12rpx;
  letter-spacing: 0.5rpx;
}

/* ===== 饮食建议 ===== */
.tip {
  padding: 22rpx 28rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, rgba(255, 157, 92, 0.05) 0%, rgba(255, 94, 133, 0.03) 100%);
  border: 1rpx solid rgba(255, 157, 92, 0.15);
}
.tip__head {
  font-size: 24rpx;
  font-weight: 700;
  color: #ff9d5c;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}
.tip__line {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 22rpx;
  color: #d0c9c0;
  padding: 4rpx 0;
}
.tip__icon { font-size: 22rpx; }

/* ===== 底部 ===== */
.footer {
  text-align: center;
  padding: 20rpx 0 0;
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: #2a2e3a;
}

.page {
  padding: 24rpx 24rpx calc(80rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  background: #0a0e17;
  box-sizing: border-box;
}

.header {
  padding: 16rpx 8rpx 32rpx;
}
.header__title {
  font-size: 40rpx;
  font-weight: 700;
  color: #f0f0f5;
  margin-bottom: 8rpx;
}
.header__desc {
  font-size: 24rpx;
  color: #4b5563;
  letter-spacing: 2rpx;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  background: rgba(0, 255, 136, 0.06);
  border: 1rpx dashed rgba(0, 255, 136, 0.3);
  border-radius: 16rpx;
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}
.add-btn__icon {
  font-size: 36rpx;
  margin-right: 12rpx;
  font-weight: 300;
}

.list { margin-top: 4rpx; }

.item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.item__body { flex: 1; min-width: 0; }
.item__name {
  font-size: 30rpx;
  font-weight: 600;
  color: #f0f0f5;
  margin-bottom: 8rpx;
}
.item__meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}
.tag {
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(0, 229, 255, 0.08);
  color: var(--cyan);
  border: 1rpx solid rgba(0, 229, 255, 0.2);
  letter-spacing: 1rpx;
}
.item__sub {
  font-size: 22rpx;
  color: #8b8fa3;
}
.item__target {
  font-size: 22rpx;
  color: #4b5563;
  font-variant-numeric: tabular-nums;
}
.item__del {
  color: #ff4d6a;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #4b5563;
}
.empty__icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty__text { font-size: 28rpx; color: #8b8fa3; margin-bottom: 8rpx; }
.empty__hint { font-size: 22rpx; color: #4b5563; }

/* ===== 表单 ===== */
.form-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.75);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.form {
  width: 100%;
  border-radius: 28rpx 28rpx 0 0;
  padding: 36rpx 36rpx calc(36rpx + env(safe-area-inset-bottom));
  max-height: 88vh;
  display: flex;
  flex-direction: column;
}
.form__title {
  font-size: 34rpx;
  font-weight: 700;
  color: #f0f0f5;
  text-align: center;
  margin-bottom: 28rpx;
}
.form__scroll {
  flex: 1;
  max-height: 62vh;
  padding: 0 4rpx;
}

.field {
  margin-bottom: 24rpx;
}
.field__label {
  font-size: 22rpx;
  color: #8b8fa3;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}
.field__input {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #f0f0f5;
  width: 100%;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  line-height: 1.4;
}
.ph {
  color: #4b5563;
  font-size: 26rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  line-height: 1.4;
}
.field__textarea {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #f0f0f5;
  width: 100%;
  height: 160rpx;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
}
.field__picker {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--primary);
}

.stepper {
  margin-bottom: 24rpx;
}
.stepper__label {
  font-size: 22rpx;
  color: #8b8fa3;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}
.stepper__row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.stepper__btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  text-align: center;
  line-height: 64rpx;
  font-size: 32rpx;
  color: #f0f0f5;
}
.stepper__btn:active { background: rgba(255, 255, 255, 0.15); }
.stepper__value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
  font-variant-numeric: tabular-nums;
  min-width: 100rpx;
  text-align: center;
}

.form__actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}
.form__btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.form__btn--cancel {
  background: rgba(255, 255, 255, 0.04);
  color: #8b8fa3;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}
.form__btn--ok {
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  color: #0a0e17;
  box-shadow: 0 0 24rpx rgba(0, 255, 136, 0.3);
}

.page {
  min-height: 100vh;
  background: #0a0e17;
  padding: 20rpx 24rpx calc(80rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ===== 搜索 ===== */
.search { margin-bottom: 16rpx; }
.search__box {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
  gap: 10rpx;
}
.search__icon { font-size: 24rpx; }
.search__input {
  flex: 1;
  font-size: 26rpx;
  color: #f0f0f5;
}

/* ===== 分类 ===== */
.cat-scroll { white-space: nowrap; margin-bottom: 20rpx; }
.cat { display: inline-flex; padding: 4rpx 0; }
.cat__item {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 24rpx;
  background: rgba(255, 255, 255, 0.04);
  color: #8b8fa3;
  border-radius: 999rpx;
  margin-right: 12rpx;
  font-size: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  white-space: nowrap;
}
.cat__item--active {
  background: rgba(0, 255, 136, 0.12);
  color: var(--primary);
  border-color: rgba(0, 255, 136, 0.3);
  box-shadow: 0 0 16rpx rgba(0, 255, 136, 0.12);
}
.cat__emoji { margin-right: 6rpx; }

/* ===== 列表 ===== */
.list { margin-top: 4rpx; }
.empty {
  text-align: center;
  color: #4b5563;
  font-size: 26rpx;
  padding: 120rpx 0;
}
.empty__icon { font-size: 64rpx; margin-bottom: 12rpx; }

.count {
  text-align: center;
  padding: 28rpx 0 8rpx;
  font-size: 18rpx;
  color: #4b5563;
  letter-spacing: 2rpx;
}

/* ===== 计划卡 ===== */
.plan-bar {
  padding: 22rpx 24rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #0d2818 0%, #0a1628 100%);
  border: 1rpx solid rgba(0, 255, 136, 0.15);
}
.plan-bar__active {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}
.plan-bar__info { flex: 1; min-width: 0; }
.plan-bar__name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #f0f0f5;
  margin-bottom: 4rpx;
}
.plan-bar__desc {
  display: block;
  font-size: 20rpx;
  color: #8b8fa3;
}
.plan-bar__actions {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}
.plan-bar__btn {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.05);
  color: #f0f0f5;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}
.plan-bar__btn--go {
  background: rgba(0, 255, 136, 0.12);
  color: #00ff88;
  border-color: rgba(0, 255, 136, 0.3);
}
.plan-bar__empty {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.plan-bar__empty-icon { font-size: 36rpx; }
.plan-bar__empty-body { flex: 1; min-width: 0; }
.plan-bar__empty-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 4rpx;
}
.plan-bar__empty-desc {
  display: block;
  font-size: 20rpx;
  color: #8b8fa3;
}
.plan-bar__empty-arrow {
  font-size: 36rpx;
  color: #4b5563;
}

/* ===== 计划选择器 ===== */
.picker-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.75);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}
.picker {
  width: 100%;
  max-width: 680rpx;
  border-radius: 28rpx;
  padding: 36rpx;
  max-height: 80vh;
  overflow-y: auto;
}
.picker__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #f0f0f5;
  text-align: center;
  margin-bottom: 24rpx;
}
.picker__item {
  padding: 22rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  margin-bottom: 12rpx;
}
.picker__item--active {
  border-color: rgba(0, 255, 136, 0.3);
  background: rgba(0, 255, 136, 0.06);
}
.picker__name {
  font-size: 28rpx;
  font-weight: 600;
  color: #f0f0f5;
  margin-bottom: 4rpx;
}
.picker__desc {
  font-size: 22rpx;
  color: #8b8fa3;
  margin-bottom: 6rpx;
}
.picker__days {
  font-size: 20rpx;
  color: var(--primary);
  letter-spacing: 1rpx;
}
.picker__add {
  text-align: center;
  padding: 22rpx;
  font-size: 26rpx;
  color: var(--primary);
  background: rgba(0, 255, 136, 0.05);
  border: 1rpx dashed rgba(0, 255, 136, 0.3);
  border-radius: 14rpx;
  margin: 12rpx 0;
}
.picker__close {
  text-align: center;
  padding: 18rpx;
  font-size: 24rpx;
  color: #8b8fa3;
}

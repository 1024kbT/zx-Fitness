.page {
  padding: 24rpx 24rpx calc(80rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  background: #0a0e17;
  box-sizing: border-box;
}

.header { padding: 16rpx 8rpx 32rpx; }
.header__title { font-size: 40rpx; font-weight: 700; color: #f0f0f5; margin-bottom: 8rpx; }
.header__desc { font-size: 24rpx; color: #4b5563; letter-spacing: 2rpx; }

.add-btn {
  display: flex; align-items: center; justify-content: center;
  padding: 28rpx;
  background: rgba(0, 255, 136, 0.06);
  border: 1rpx dashed rgba(0, 255, 136, 0.3);
  border-radius: 16rpx;
  color: var(--primary);
  font-size: 28rpx; font-weight: 600;
  margin-bottom: 24rpx;
}
.add-btn__icon { font-size: 36rpx; margin-right: 12rpx; font-weight: 300; }

.list { margin-top: 4rpx; }

.plan {
  padding: 28rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s ease;
}
.plan--expanded {
  padding: 28rpx 28rpx 20rpx;
  border-color: rgba(0, 255, 136, 0.2);
  box-shadow: 0 0 24rpx rgba(0, 255, 136, 0.06);
}

.plan__head {
  display: flex; align-items: center; justify-content: space-between;
}
.plan__info { flex: 1; min-width: 0; }
.plan__name {
  font-size: 30rpx; font-weight: 600; color: #f0f0f5;
  margin-bottom: 6rpx;
}
.plan__desc {
  font-size: 22rpx; color: #8b8fa3;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.plan__right {
  display: flex; align-items: center; gap: 12rpx;
  flex-shrink: 0;
}
.plan__days-count {
  font-size: 22rpx; color: var(--primary);
  padding: 6rpx 14rpx;
  background: rgba(0, 255, 136, 0.08);
  border-radius: 999rpx;
  border: 1rpx solid rgba(0, 255, 136, 0.2);
}
.plan__arrow {
  font-size: 36rpx; color: #4b5563;
  transform: rotate(90deg);
  transition: transform 0.2s;
  font-weight: 300;
}
.plan__arrow--up { transform: rotate(-90deg); }

/* ===== 计划展开后的编辑区 ===== */
.plan__body {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}

.plan__meta-row {
  display: flex; gap: 12rpx;
  margin-bottom: 20rpx;
}
.plan__inline-input {
  flex: 1;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 10rpx;
  padding: 14rpx 18rpx;
  font-size: 24rpx;
  color: #f0f0f5;
}
.plan__inline-input--sm { flex: 0.8; }

.days-toolbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12rpx 4rpx;
}
.days-toolbar__title {
  font-size: 22rpx; color: #8b8fa3; letter-spacing: 2rpx;
}
.days-toolbar__add {
  font-size: 22rpx; color: var(--primary);
  padding: 6rpx 14rpx;
  background: rgba(0, 255, 136, 0.06);
  border: 1rpx solid rgba(0, 255, 136, 0.2);
  border-radius: 999rpx;
  font-weight: 600;
}

.inline-days { display: flex; flex-direction: column; gap: 10rpx; }

.inline-day {
  background: rgba(255, 255, 255, 0.025);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: 14rpx;
  overflow: hidden;
  transition: all 0.2s;
}
.inline-day--active {
  border-color: rgba(0, 229, 255, 0.3);
  background: rgba(0, 229, 255, 0.04);
}

.inline-day__head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx;
}
.inline-day__info { flex: 1; min-width: 0; }
.inline-day__label {
  font-size: 26rpx; font-weight: 600; color: #f0f0f5;
  margin-bottom: 4rpx;
}
.inline-day__sub {
  display: flex; gap: 8rpx; align-items: center;
  font-size: 20rpx; color: #4b5563;
}
.inline-day__dow { letter-spacing: 1rpx; }
.inline-day__muscle {
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  max-width: 280rpx;
}
.inline-day__count {
  font-size: 20rpx; color: var(--cyan);
  padding: 4rpx 12rpx;
  background: rgba(0, 229, 255, 0.08);
  border: 1rpx solid rgba(0, 229, 255, 0.2);
  border-radius: 999rpx;
  flex-shrink: 0;
}

.inline-day__body {
  padding: 16rpx 20rpx 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}

.inline-day__fields { margin-bottom: 16rpx; }
.inline-day__input {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 10rpx;
  padding: 14rpx 16rpx;
  font-size: 24rpx; color: #f0f0f5;
  width: 100%;
  margin-bottom: 10rpx;
  box-sizing: border-box;
}
.inline-day__row { display: flex; gap: 10rpx; align-items: center; }
.inline-day__input--grow { flex: 1; margin-bottom: 0; }
.inline-day__picker {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 10rpx;
  padding: 14rpx 16rpx;
  font-size: 24rpx; color: var(--primary);
  white-space: nowrap;
}

.ex-toolbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 8rpx 4rpx 12rpx;
}
.ex-toolbar__title { font-size: 22rpx; color: #8b8fa3; letter-spacing: 1rpx; }
.ex-toolbar__btn {
  font-size: 22rpx; color: var(--primary);
  padding: 6rpx 16rpx;
  background: rgba(0, 255, 136, 0.06);
  border: 1rpx solid rgba(0, 255, 136, 0.25);
  border-radius: 999rpx;
  font-weight: 600;
}

.ex-list {
  display: flex; flex-wrap: wrap; gap: 8rpx;
  min-height: 60rpx;
  padding: 8rpx 0 12rpx;
}
.ex-chip-item {
  display: inline-flex; align-items: center;
  background: rgba(0, 229, 255, 0.08);
  border: 1rpx solid rgba(0, 229, 255, 0.2);
  border-radius: 999rpx;
  padding: 6rpx 12rpx 6rpx 16rpx;
}
.ex-chip-name { font-size: 22rpx; color: var(--cyan); }
.ex-chip-del {
  margin-left: 8rpx;
  color: #ff4d6a;
  font-size: 26rpx;
  padding: 0 4rpx;
}
.ex-list__empty {
  font-size: 22rpx; color: #4b5563;
  width: 100%; text-align: center; padding: 16rpx 0;
}

.inline-day__danger {
  margin-top: 16rpx;
  text-align: center;
  padding: 14rpx;
  font-size: 22rpx;
  color: #ff4d6a;
  background: rgba(255, 77, 106, 0.06);
  border: 1rpx solid rgba(255, 77, 106, 0.15);
  border-radius: 10rpx;
}

.inline-days__empty {
  text-align: center; color: #4b5563;
  font-size: 22rpx; padding: 28rpx 0;
}

.plan__footer {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}
.plan__footer__btn {
  text-align: center;
  padding: 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}
.plan__footer__btn--danger {
  color: #ff4d6a;
  background: rgba(255, 77, 106, 0.06);
  border: 1rpx solid rgba(255, 77, 106, 0.2);
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #4b5563;
}
.empty__icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty__text { font-size: 28rpx; color: #8b8fa3; margin-bottom: 8rpx; }
.empty__hint { font-size: 22rpx; color: #4b5563; }

/* ===== 弹窗（新建计划 + 动作选择） ===== */
.form-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.75);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}
.form {
  width: 100%;
  max-width: 680rpx;
  border-radius: 28rpx;
  padding: 40rpx 36rpx calc(40rpx + env(safe-area-inset-bottom));
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}
.form--mini {
  max-height: none;
}
.form__title {
  font-size: 34rpx; font-weight: 700; color: #f0f0f5;
  text-align: center; margin-bottom: 36rpx;
}

.field { margin-bottom: 28rpx; }
.field__label {
  font-size: 24rpx; color: #8b8fa3; margin-bottom: 14rpx; letter-spacing: 1rpx;
}
.field__input {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 26rpx 28rpx;
  font-size: 30rpx;
  color: #f0f0f5;
  width: 100%;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  line-height: 1.4;
}
.ph {
  color: #4b5563;
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  line-height: 1.4;
}

.form__actions {
  display: flex; gap: 20rpx;
  margin-top: 28rpx; padding-top: 28rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}
.form__btn {
  flex: 1; text-align: center; padding: 28rpx;
  border-radius: 999rpx; font-size: 30rpx; font-weight: 600;
}
.form__btn--cancel {
  background: rgba(255, 255, 255, 0.06);
  color: #8b8fa3;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}
.form__btn--ok {
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  color: #0a0e17;
  box-shadow: 0 0 24rpx rgba(0, 255, 136, 0.3);
}

/* ===== 动作选择器 ===== */
.ex-search { margin-bottom: 16rpx; }
.ex-search__input {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx; color: #f0f0f5;
  width: 100%; box-sizing: border-box;
}
.ex-picker-list {
  flex: 1;
  max-height: 50vh;
  padding: 0 4rpx;
}
.ex-pick {
  display: flex; align-items: center;
  padding: 18rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}
.ex-pick--on {
  background: rgba(0, 255, 136, 0.06);
  border-color: rgba(0, 255, 136, 0.3);
}
.ex-pick__info { flex: 1; min-width: 0; }
.ex-pick__name { font-size: 26rpx; color: #f0f0f5; margin-bottom: 4rpx; }
.ex-pick__sub {
  font-size: 20rpx; color: #4b5563;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.ex-pick__check {
  color: var(--primary);
  font-size: 30rpx; font-weight: 700;
  margin-left: 16rpx;
}
.ex-picker-list__empty {
  text-align: center; color: #4b5563;
  padding: 80rpx 0; font-size: 24rpx;
}

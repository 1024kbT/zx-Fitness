.page {
  min-height: 100vh;
  background: #0a0e17;
  display: flex;
  flex-direction: column;
}

/* ===== 顶栏（胶囊安全区） ===== */
.topbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: rgba(10, 14, 23, 0.95);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(20px);
  z-index: 800;
}
.topbar__inner {
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  box-sizing: border-box;
}
.topbar__info { flex: 1; min-width: 0; }
.topbar__title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #f0f0f5;
}
.topbar__icon { font-size: 32rpx; }
.topbar__sub {
  font-size: 20rpx;
  color: #4b5563;
  letter-spacing: 1rpx;
  margin-top: 4rpx;
}
.topbar__btn {
  font-size: 24rpx;
  color: #ff4d6a;
  padding: 8rpx 20rpx;
  background: rgba(255, 77, 106, 0.06);
  border: 1rpx solid rgba(255, 77, 106, 0.2);
  border-radius: 999rpx;
}

/* ===== 聊天区 ===== */
.chat {
  flex: 1;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
  height: 0;
}

/* ===== 欢迎卡 ===== */
.welcome {
  padding: 32rpx 28rpx 28rpx;
  margin-bottom: 24rpx;
  text-align: center;
}
.welcome__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #f0f0f5;
  margin-bottom: 12rpx;
}
.welcome__desc {
  font-size: 26rpx;
  color: #8b8fa3;
  line-height: 1.6;
  margin-bottom: 32rpx;
  padding: 0 12rpx;
}
.welcome__hint {
  font-size: 22rpx;
  color: #4b5563;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
  text-align: left;
  padding-left: 8rpx;
}

/* ===== 灵动能量球 ===== */
.orb-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 32rpx 0 24rpx;
}

.orb {
  position: relative;
  width: 280rpx;
  height: 280rpx;
}

/* 外层光晕 */
.orb__halo {
  position: absolute;
  top: -50rpx; left: -50rpx; right: -50rpx; bottom: -50rpx;
  border-radius: 50%;
  background: radial-gradient(circle,
    rgba(0, 229, 255, 0.35) 0%,
    rgba(167, 139, 250, 0.18) 35%,
    transparent 65%);
  animation: orb-pulse 3.6s ease-in-out infinite;
}

/* 底色层：渐变金属球 */
.orb::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 25%,
    #d8f4ff 0%,
    #5fcfe8 18%,
    #6b7adb 45%,
    #2a1e5c 75%,
    #0a0e17 100%);
  box-shadow:
    inset -20rpx -30rpx 60rpx rgba(0, 0, 0, 0.55),
    inset 12rpx 14rpx 30rpx rgba(255, 255, 255, 0.18),
    0 0 80rpx rgba(0, 229, 255, 0.45),
    0 12rpx 32rpx rgba(167, 139, 250, 0.3);
}

/* 流动光带 1 —— 青色 conic */
.orb__layer {
  position: absolute;
  inset: 6rpx;
  border-radius: 50%;
  pointer-events: none;
  mix-blend-mode: screen;
}
.orb__layer--1 {
  background: conic-gradient(from 0deg,
    transparent 0%,
    rgba(0, 229, 255, 0.85) 18%,
    transparent 38%,
    rgba(0, 255, 200, 0.5) 60%,
    transparent 78%,
    rgba(0, 229, 255, 0.65) 92%,
    transparent 100%);
  filter: blur(8rpx);
  animation: orb-spin 6s linear infinite;
  opacity: 0.85;
}
.orb__layer--2 {
  background: conic-gradient(from 120deg,
    transparent 0%,
    rgba(167, 139, 250, 0.7) 22%,
    transparent 42%,
    rgba(216, 180, 254, 0.55) 65%,
    transparent 88%);
  filter: blur(10rpx);
  animation: orb-spin-rev 9s linear infinite;
  opacity: 0.75;
}
.orb__layer--3 {
  background: conic-gradient(from 240deg,
    transparent 0%,
    rgba(255, 255, 255, 0.55) 12%,
    transparent 28%,
    transparent 100%);
  filter: blur(6rpx);
  animation: orb-spin 4s linear infinite;
  opacity: 0.6;
}

/* 顶部高光 */
.orb__highlight {
  position: absolute;
  top: 15%;
  left: 22%;
  width: 38%;
  height: 28%;
  border-radius: 50%;
  background: radial-gradient(ellipse,
    rgba(255, 255, 255, 0.7) 0%,
    rgba(255, 255, 255, 0.2) 40%,
    transparent 75%);
  filter: blur(4rpx);
  pointer-events: none;
}

/* 流动高光带 —— 额外的金属反射 */
.orb__shine {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: linear-gradient(120deg,
    transparent 35%,
    rgba(255, 255, 255, 0.25) 48%,
    rgba(255, 255, 255, 0.5) 50%,
    rgba(255, 255, 255, 0.25) 52%,
    transparent 65%);
  filter: blur(2rpx);
  animation: orb-shine 4.5s ease-in-out infinite;
  pointer-events: none;
  opacity: 0.7;
}

/* 激活状态（AI 思考中）：加快且增强 */
.orb--active .orb__halo {
  animation-duration: 1.4s;
  background: radial-gradient(circle,
    rgba(0, 255, 136, 0.45) 0%,
    rgba(0, 229, 255, 0.25) 35%,
    transparent 65%);
}
.orb--active .orb__layer--1 { animation-duration: 2s; }
.orb--active .orb__layer--2 { animation-duration: 3s; }
.orb--active .orb__layer--3 { animation-duration: 1.5s; }
.orb--active .orb__shine { animation-duration: 1.5s; }

/* 迷你球（顶栏用） */
.orb--mini {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
}
.orb--mini .orb__halo {
  top: -10rpx; left: -10rpx; right: -10rpx; bottom: -10rpx;
}
.orb--mini .orb__layer {
  inset: 2rpx;
  filter: blur(3rpx);
}
.orb--mini .orb__highlight {
  filter: blur(1rpx);
}

@keyframes orb-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
@keyframes orb-spin-rev {
  from { transform: rotate(0deg); }
  to { transform: rotate(-360deg); }
}
@keyframes orb-pulse {
  0%, 100% { opacity: 0.7; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.08); }
}
@keyframes orb-shine {
  0% { transform: translateX(-30%) rotate(-10deg); opacity: 0; }
  40% { opacity: 0.7; }
  60% { opacity: 0.7; }
  100% { transform: translateX(30%) rotate(10deg); opacity: 0; }
}
.quick-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.quick-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 24rpx;
  background: rgba(0, 255, 136, 0.04);
  border: 1rpx solid rgba(0, 255, 136, 0.15);
  border-radius: 14rpx;
}
.quick-item__label {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}
.quick-item__arrow {
  font-size: 30rpx;
  color: var(--primary);
}

/* ===== 消息气泡 ===== */
.msg {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  gap: 12rpx;
}
.msg--user { flex-direction: row; justify-content: flex-end; }
.msg--assistant { flex-direction: row; }

.msg__avatar {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}
.msg__avatar--user {
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  color: #0a0e17;
  box-shadow: 0 0 16rpx rgba(0, 255, 136, 0.25);
}
.msg__avatar--ai {
  background: rgba(0, 229, 255, 0.12);
  color: var(--cyan);
  border: 1rpx solid rgba(0, 229, 255, 0.3);
}

.msg__bubble {
  max-width: 540rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
}
.msg__bubble--user {
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  color: #0a0e17;
  border-bottom-right-radius: 6rpx;
  font-weight: 500;
}
.msg__bubble--ai {
  background: rgba(255, 255, 255, 0.04);
  color: #f0f0f5;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-bottom-left-radius: 6rpx;
}
.msg__bubble--error {
  background: rgba(255, 77, 106, 0.08);
  border-color: rgba(255, 77, 106, 0.3);
  color: #ff4d6a;
}
.msg__bubble--pending {
  background: rgba(0, 229, 255, 0.04);
  border-color: rgba(0, 229, 255, 0.15);
}

.msg__text { white-space: pre-wrap; }

/* ===== 加载点 ===== */
.dot-loading {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 36rpx;
}
.dot-loading__dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--cyan);
  animation: dot-bounce 1.2s infinite ease-in-out;
}
.dot-loading__dot:nth-child(2) { animation-delay: 0.2s; }
.dot-loading__dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes dot-bounce {
  0%, 60%, 100% { transform: scale(0.6); opacity: 0.4; }
  30% { transform: scale(1); opacity: 1; }
}

.chat__bottom-pad { height: 40rpx; }

/* ===== 输入区 ===== */
.composer {
  background: rgba(10, 14, 23, 0.98);
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.4);
}
.composer__chips {
  white-space: nowrap;
  margin-bottom: 14rpx;
}
.composer__chips-inner {
  display: inline-flex;
  gap: 10rpx;
  padding: 4rpx 0;
}
.composer__chip {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: rgba(0, 229, 255, 0.06);
  border: 1rpx solid rgba(0, 229, 255, 0.2);
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #00e5ff;
  font-weight: 500;
  letter-spacing: 0.5rpx;
  transition: all 0.15s;
}
.composer__chip:active {
  background: rgba(0, 229, 255, 0.15);
  transform: scale(0.96);
}
.composer__inner {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.composer__input {
  flex: 1;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 999rpx;
  padding: 22rpx 28rpx;
  font-size: 28rpx;
  color: #f0f0f5;
  min-height: 72rpx;
  box-sizing: border-box;
}
.composer__placeholder { color: #4b5563; }
.composer__send {
  flex-shrink: 0;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.04);
  color: #4b5563;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}
.composer__send--active {
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  color: #0a0e17;
  border-color: transparent;
  box-shadow: 0 0 20rpx rgba(0, 255, 136, 0.3);
}

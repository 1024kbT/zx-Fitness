.workout {
  padding: 24rpx;
  padding-bottom: 280rpx;
  min-height: 100vh;
  background: #0a0e17;
}

/* ===== 头部 ===== */
.head { margin-bottom: 20rpx; }
.head__step {
  display: inline-block;
  font-size: 20rpx;
  color: #00e5ff;
  background: rgba(0, 229, 255, 0.08);
  border: 1rpx solid rgba(0, 229, 255, 0.2);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
}

/* ===== Session 进度条 ===== */
.session-bar {
  margin-bottom: 16rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #0d2818 0%, #0a1628 100%);
  border: 1rpx solid rgba(0, 255, 136, 0.15);
}
.session-bar__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}
.session-bar__plan {
  font-size: 24rpx;
  color: #f0f0f5;
  font-weight: 600;
}
.session-bar__progress {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}
.session-bar__done {
  font-size: 32rpx;
  font-weight: 700;
  color: #00ff88;
  text-shadow: 0 0 12rpx rgba(0, 255, 136, 0.4);
}
.session-bar__slash { font-size: 22rpx; color: #4b5563; }
.session-bar__total { font-size: 26rpx; color: #8b8fa3; }
.session-bar__label { font-size: 20rpx; color: #8b8fa3; margin-left: 6rpx; }

.session-bar__icons {
  white-space: nowrap;
  margin-bottom: 14rpx;
}
.session-bar__icons::-webkit-scrollbar { display: none; }
.session-icons {
  display: inline-flex;
  gap: 14rpx;
  padding: 6rpx 4rpx;
}
.session-icon {
  position: relative;
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1a2030 0%, #0f1520 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: inset 0 2rpx 6rpx rgba(255, 255, 255, 0.05), 0 2rpx 8rpx rgba(0, 0, 0, 0.4);
  transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}
.session-icon--pending {
  opacity: 0.55;
  filter: grayscale(0.5);
}
.session-icon--current {
  background: linear-gradient(135deg, #00e5ff 0%, #6c5ce7 100%);
  border-color: #00e5ff;
  box-shadow: 0 0 20rpx rgba(0, 229, 255, 0.6), 0 0 40rpx rgba(0, 229, 255, 0.3), inset 0 2rpx 8rpx rgba(255, 255, 255, 0.2);
  transform: scale(1.12);
  animation: iconPulse 2s ease-in-out infinite;
}
.session-icon--done {
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  border-color: #00ff88;
  box-shadow: 0 0 18rpx rgba(0, 255, 136, 0.5), 0 0 30rpx rgba(0, 255, 136, 0.25);
}
.session-icon--active {
  transform: scale(1.18);
}
.session-icon__emoji {
  font-size: 34rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.3));
}
.session-icon--done .session-icon__emoji {
  opacity: 0.6;
}
.session-icon__check {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #0a0e17;
  color: #00ff88;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 900;
  border: 2rpx solid #00ff88;
  box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.6);
}
@keyframes iconPulse {
  0%, 100% { box-shadow: 0 0 20rpx rgba(0, 229, 255, 0.6), 0 0 40rpx rgba(0, 229, 255, 0.3); }
  50% { box-shadow: 0 0 28rpx rgba(0, 229, 255, 0.9), 0 0 60rpx rgba(0, 229, 255, 0.5); }
}

.session-bar__swipe-hint {
  text-align: center;
  font-size: 18rpx;
  color: #4b5563;
  letter-spacing: 3rpx;
  margin-top: 10rpx;
}

/* ===== Head Swiper ===== */
.head-swiper {
  height: 480rpx;
  margin-bottom: 20rpx;
}
.head--swipe {
  height: 440rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  background: linear-gradient(160deg, rgba(13, 40, 24, 0.9) 0%, rgba(10, 22, 40, 0.9) 60%, rgba(14, 10, 40, 0.9) 100%);
  border: 1rpx solid rgba(0, 229, 255, 0.2);
  border-radius: 28rpx;
  padding: 16rpx 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  transition: transform 0.25s ease;
  text-align: center;
}
.head--swipe .head__image-wrap {
  width: 320rpx;
  height: 220rpx;
  margin: 4rpx auto 10rpx;
}
.head--swipe .head__image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}
.head--swipe .head__emoji {
  position: relative;
  font-size: 110rpx;
  text-align: center;
  margin: 6rpx 0 14rpx;
  filter: drop-shadow(0 0 24rpx rgba(0, 229, 255, 0.4));
  animation: emojiFloat 3s ease-in-out infinite;
}
.head--swipe .head__emoji::before {
  content: '';
  position: absolute;
  inset: -20rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0, 229, 255, 0.2) 0%, transparent 70%);
  z-index: -1;
  animation: emojiHalo 3s ease-in-out infinite;
}
.head--swipe .head__image-loading {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}
.head--swipe .head__loading-text {
  font-size: 18rpx;
  color: #4b5563;
  background: rgba(10, 14, 23, 0.7);
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  letter-spacing: 1rpx;
}
.head--swipe .head__image-fallback {
  position: absolute;
  bottom: 8rpx;
  left: 0;
  right: 0;
  text-align: center;
}
.head--swipe .head__fallback-label {
  font-size: 18rpx;
  color: #4b5563;
  letter-spacing: 1rpx;
  background: rgba(10, 14, 23, 0.7);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}
@keyframes emojiFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}
@keyframes emojiHalo {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.1); }
}
.head--swipe .head__name {
  font-size: 40rpx;
  font-weight: 700;
  color: #f0f0f5;
  text-align: center;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}
.head--swipe .head__meta {
  text-align: center;
  margin-bottom: 14rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10rpx;
}
.head--swipe .head__sub {
  font-size: 22rpx;
  color: #8b8fa3;
  letter-spacing: 1rpx;
}
.head--swipe .head__target {
  font-size: 24rpx;
  color: #f0f0f5;
  font-variant-numeric: tabular-nums;
  padding: 10rpx 24rpx;
  background: rgba(0, 229, 255, 0.08);
  border: 1rpx solid rgba(0, 229, 255, 0.25);
  border-radius: 999rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  display: inline-block;
}
.head--swipe .head__status {
  text-align: center;
  margin-top: 14rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  display: inline-block;
}
.head--swipe .head__status--done {
  color: #00ff88;
  background: rgba(0, 255, 136, 0.12);
  border: 1rpx solid rgba(0, 255, 136, 0.3);
  box-shadow: 0 0 12rpx rgba(0, 255, 136, 0.3);
}
.head--swipe .head__status--pending {
  color: #8b8fa3;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

/* ===== 单动作头部（非计划模式，左对齐紧凑） ===== */
.head--single {
  padding: 24rpx 28rpx;
  background: linear-gradient(160deg, rgba(13, 40, 24, 0.6) 0%, rgba(10, 22, 40, 0.7) 100%);
  border: 1rpx solid rgba(0, 229, 255, 0.15);
  border-radius: 20rpx;
}
.head--single .head__name {
  font-size: 42rpx;
  font-weight: 700;
  color: #f0f0f5;
  margin-bottom: 14rpx;
  letter-spacing: 1rpx;
  text-align: left;
  line-height: 1.2;
}
.head--single .head__meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}
.head--single .head__meta .tag {
  padding: 6rpx 14rpx;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 999rpx;
  background: rgba(0, 255, 136, 0.1);
  color: #00ff88;
  border: 1rpx solid rgba(0, 255, 136, 0.25);
  letter-spacing: 1rpx;
  line-height: 1;
}
.head--single .head__sub {
  font-size: 22rpx;
  color: #8b8fa3;
  letter-spacing: 0.5rpx;
  line-height: 1;
}
.head--single .head__target {
  display: inline-block;
  font-size: 24rpx;
  color: #f0f0f5;
  font-variant-numeric: tabular-nums;
  padding: 10rpx 22rpx;
  background: rgba(0, 229, 255, 0.1);
  border: 1rpx solid rgba(0, 229, 255, 0.3);
  border-radius: 999rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  line-height: 1;
}

.session-bar__bar {
  height: 6rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 3rpx;
  overflow: hidden;
}
.session-bar__fill {
  height: 100%;
  background: linear-gradient(90deg, #00ff88, #00e5ff);
  border-radius: 3rpx;
  transition: width 0.4s ease;
  box-shadow: 0 0 12rpx rgba(0, 255, 136, 0.4);
}

/* ===== 休息倒计时抽屉（底部半屏） ===== */
.rest-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(10, 14, 23, 0.55);
  backdrop-filter: blur(8px);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  animation: maskIn 0.25s ease both;
}
.rest-drawer {
  width: 100%;
  max-width: 750rpx;
  background: linear-gradient(180deg, #0d2818 0%, #0a1628 60%, #0e0a28 100%);
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(0, 229, 255, 0.2);
  box-shadow: 0 -20rpx 60rpx rgba(0, 0, 0, 0.5), 0 0 60rpx rgba(0, 229, 255, 0.1);
  animation: drawerUp 0.35s cubic-bezier(0.22, 1, 0.36, 1) both;
  text-align: center;
}
@keyframes drawerUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.rest-drawer__label {
  font-size: 20rpx;
  letter-spacing: 8rpx;
  color: #00e5ff;
  margin-bottom: 16rpx;
}
.rest-drawer__time {
  font-size: 160rpx;
  font-weight: 200;
  font-variant-numeric: tabular-nums;
  color: #00e5ff;
  text-shadow: 0 0 60rpx rgba(0, 229, 255, 0.4);
  font-family: -apple-system, "SF Mono", monospace;
  line-height: 1;
  margin-bottom: 20rpx;
  transition: opacity 0.3s;
}
.rest-drawer__time--paused {
  animation: timeBlink 1s ease-in-out infinite;
  color: #8b8fa3;
}
@keyframes timeBlink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}
.rest-drawer__bar {
  width: 100%;
  height: 8rpx;
  border-radius: 4rpx;
  background: rgba(255, 255, 255, 0.06);
  margin-bottom: 28rpx;
  overflow: hidden;
}
.rest-drawer__fill {
  height: 100%;
  border-radius: 4rpx;
  background: linear-gradient(90deg, #00ff88, #00e5ff);
  box-shadow: 0 0 12rpx rgba(0, 229, 255, 0.4);
  transition: width 0.3s ease;
}
.rest-drawer__pause {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 24rpx;
  color: #8b8fa3;
  font-size: 24rpx;
  letter-spacing: 2rpx;
}
.rest-drawer__pause-icon {
  font-size: 32rpx;
  color: #00e5ff;
}
.rest-drawer__pause-text {
  color: #00e5ff;
  font-weight: 500;
}
.rest-drawer__tune {
  display: flex;
  gap: 14rpx;
  justify-content: center;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}
.rest-drawer__btn {
  padding: 24rpx 32rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  border: 1rpx solid transparent;
  transition: transform 0.15s;
}
.rest-drawer__btn:active { transform: scale(0.96); }
.rest-drawer__btn--ghost {
  background: rgba(255, 255, 255, 0.04);
  color: #8b8fa3;
  border-color: rgba(255, 255, 255, 0.08);
  font-size: 24rpx;
  padding: 18rpx 28rpx;
}
.rest-drawer__actions {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}
.rest-drawer__btn--primary {
  flex: 2;
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  color: #0a0e17;
  font-size: 34rpx;
  font-weight: 700;
  padding: 32rpx 32rpx;
  box-shadow: 0 0 24rpx rgba(0, 255, 136, 0.35);
}
.rest-drawer__btn--secondary {
  flex: 1;
  background: rgba(0, 229, 255, 0.12);
  color: #00e5ff;
  border-color: rgba(0, 229, 255, 0.3);
  font-size: 28rpx;
}

/* ===== 休息配置 ===== */
.rest-config { margin-bottom: 20rpx; }
.rest-config__title {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #4b5563;
  margin-bottom: 18rpx;
}
.rest-config__durations {
  display: flex;
  gap: 12rpx;
  margin-bottom: 18rpx;
  flex-wrap: wrap;
}
.rest-chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #8b8fa3;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  font-variant-numeric: tabular-nums;
}
.rest-chip--on {
  background: rgba(0, 255, 136, 0.1);
  color: var(--primary);
  border-color: rgba(0, 255, 136, 0.3);
  box-shadow: 0 0 16rpx rgba(0, 255, 136, 0.1);
}
.rest-config__modes {
  display: flex;
  gap: 10rpx;
}
.rest-mode {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}
.rest-mode--on {
  background: rgba(0, 229, 255, 0.08);
  border-color: rgba(0, 229, 255, 0.3);
}
.rest-mode__icon {
  display: block;
  font-size: 28rpx;
  margin-bottom: 6rpx;
}
.rest-mode__text {
  display: block;
  font-size: 20rpx;
  color: #8b8fa3;
  letter-spacing: 1rpx;
}
.rest-mode--on .rest-mode__text {
  color: var(--cyan);
}

/* ===== 计时器（小标签，降级显示） ===== */
.timer-mini {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  padding: 12rpx 0;
  margin-bottom: 16rpx;
  color: #4b5563;
  font-variant-numeric: tabular-nums;
  font-size: 22rpx;
  letter-spacing: 2rpx;
}
.timer-mini__label {
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: #4b5563;
  opacity: 0.7;
}

/* ===== 组数 ===== */
.sets { margin-bottom: 20rpx; }
.sets__title { font-size: 20rpx; letter-spacing: 4rpx; color: #4b5563; margin-bottom: 8rpx; }
.sets__target { font-size: 24rpx; color: #8b8fa3; }
.sets__count { display: flex; align-items: baseline; }
.sets__num {
  font-size: 72rpx; font-weight: 700; color: var(--primary);
  font-variant-numeric: tabular-nums; text-shadow: 0 0 40rpx rgba(0, 255, 136, 0.35);
}
.sets__total { font-size: 28rpx; color: #4b5563; margin-left: 8rpx; }
.sets__progress { margin-top: 20rpx; }
.sets__progress-bar { height: 8rpx; border-radius: 4rpx; background: rgba(255, 255, 255, 0.06); overflow: hidden; }
.sets__progress-fill {
  height: 100%; border-radius: 4rpx;
  background: linear-gradient(90deg, #00ff88, #00e5ff);
  box-shadow: 0 0 16rpx rgba(0, 255, 136, 0.4);
  transition: width 0.4s ease;
}
/* 组详情 */
.sets__logs { margin-top: 16rpx; }
.sets__log {
  display: flex; justify-content: space-between;
  padding: 8rpx 0; border-bottom: 1rpx solid rgba(255, 255, 255, 0.03);
}
.sets__log-index { font-size: 22rpx; color: #4b5563; }
.sets__log-detail { font-size: 22rpx; color: #8b8fa3; font-variant-numeric: tabular-nums; }

.sets__adjust { display: flex; align-items: center; justify-content: center; margin-top: 24rpx; gap: 36rpx; }
.sets__btn {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: rgba(255, 255, 255, 0.06); border: 1rpx solid rgba(255, 255, 255, 0.1);
  text-align: center; line-height: 64rpx; font-size: 36rpx; color: #f0f0f5;
}
.sets__btn:active { background: rgba(255, 255, 255, 0.12); }
.sets__adjust-label { font-size: 22rpx; color: #4b5563; letter-spacing: 2rpx; }

/* ===== 当前组 ===== */
.current-set { margin-bottom: 20rpx; }
.current-set__title {
  font-size: 20rpx; letter-spacing: 4rpx; color: #4b5563; margin-bottom: 24rpx;
}
.current-set__row {
  display: flex; align-items: center;
}
.current-set__field { flex: 1; text-align: center; }
.current-set__field--full { flex: 1; }
.current-set__field--full .current-set__value { font-size: 64rpx; }
.current-set__label {
  font-size: 18rpx; letter-spacing: 3rpx; color: #4b5563; margin-bottom: 16rpx;
}
.current-set__controls {
  display: flex; align-items: center; justify-content: center; gap: 24rpx;
}
.current-set__btn {
  width: 60rpx; height: 60rpx; border-radius: 50%;
  background: rgba(255, 255, 255, 0.06); border: 1rpx solid rgba(255, 255, 255, 0.1);
  text-align: center; line-height: 60rpx; font-size: 32rpx; color: #f0f0f5;
}
.current-set__btn:active { background: rgba(255, 255, 255, 0.12); }
.current-set__value {
  font-size: 48rpx; font-weight: 700; color: #f0f0f5;
  font-variant-numeric: tabular-nums; min-width: 80rpx; text-align: center;
}
.current-set__value--green { color: var(--primary); text-shadow: 0 0 20rpx rgba(0, 255, 136, 0.3); }
.current-set__divider { width: 2rpx; height: 80rpx; background: rgba(255, 255, 255, 0.04); }

/* ===== 要领（可折叠） ===== */
.tips { margin-bottom: 20rpx; }
.tips--foldable { padding: 20rpx 24rpx; }
.tips__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 4rpx 0;
}
.tips__title { font-size: 20rpx; letter-spacing: 4rpx; color: #4b5563; }
.tips__arrow {
  font-size: 36rpx;
  color: #4b5563;
  transform: rotate(90deg);
  transition: transform 0.25s ease;
  display: inline-block;
  margin-right: 4rpx;
}
.tips__arrow--on { transform: rotate(-90deg); }
.tips__body { padding-top: 16rpx; }
.tips__item { display: flex; align-items: flex-start; margin-top: 12rpx; }
.tips__dot {
  flex-shrink: 0; width: 36rpx; height: 36rpx; border-radius: 50%;
  background: rgba(0, 255, 136, 0.08); border: 1rpx solid rgba(0, 255, 136, 0.2);
  color: var(--primary); text-align: center; line-height: 36rpx;
  font-size: 22rpx; font-weight: 600; margin-right: 16rpx; margin-top: 4rpx;
}
.tips__text { flex: 1; font-size: 26rpx; color: #8b8fa3; line-height: 1.7; }

/* ===== 操作区 ===== */
.actions {
  position: fixed; left: 0; right: 0; bottom: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(10, 14, 23, 0) 0%, #0a0e17 30%);
}
.actions__main { font-size: 34rpx; padding: 32rpx; margin-bottom: 16rpx; }
.actions__row { display: flex; gap: 16rpx; }
.actions__sec {
  flex: 1; text-align: center; padding: 22rpx; border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.04); color: #f0f0f5; font-size: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}
.actions__sec--danger { color: #ff4d6a; border-color: rgba(255, 77, 106, 0.2); }
.actions__sec:active { background: rgba(255, 255, 255, 0.08); }

/* ===== 滑块完成一组 ===== */
.swipe-wrap {
  margin-bottom: 20rpx;
  padding: 16rpx 8rpx 4rpx;
}
.swipe-track {
  position: relative;
  height: 100rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  overflow: hidden;
}
.swipe-track__fill {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(90deg, rgba(0, 255, 136, 0.15) 0%, rgba(0, 255, 136, 0.35) 100%);
  border-radius: 999rpx 0 0 999rpx;
  transition: width 0.1s linear;
  pointer-events: none;
}
.swipe-track__text {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #8b8fa3;
  letter-spacing: 2rpx;
  pointer-events: none;
  font-weight: 500;
}
.swipe-track__text--mid {
  color: #00e5ff;
}
.swipe-track__text--done {
  color: #00ff88;
  font-weight: 700;
  text-shadow: 0 0 12rpx rgba(0, 255, 136, 0.5);
}
.swipe-thumb {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  box-shadow: 0 0 20rpx rgba(0, 255, 136, 0.5), 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  left: 0;
  z-index: 2;
}
.swipe-thumb:active {
  transform: translate(-50%, -50%) scale(1.05);
}
.swipe-thumb__icon {
  font-size: 32rpx;
  color: #0a0e17;
  font-weight: 700;
  margin-left: 4rpx;
}
.swipe-hint {
  text-align: center;
  font-size: 20rpx;
  color: #4b5563;
  margin-top: 12rpx;
  letter-spacing: 1rpx;
  font-variant-numeric: tabular-nums;
}

/* ===== 训练完成弹窗 ===== */
.done-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(10, 14, 23, 0.88);
  backdrop-filter: blur(20px);
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  animation: maskIn 0.3s ease both;
}
@keyframes maskIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
.done-card {
  width: 100%;
  max-width: 640rpx;
  background: linear-gradient(160deg, #0d2818 0%, #0a1628 60%, #0e0a28 100%);
  border: 1rpx solid rgba(0, 255, 136, 0.2);
  border-radius: 32rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.5), 0 0 60rpx rgba(0, 255, 136, 0.15);
  animation: cardIn 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
}
@keyframes cardIn {
  from {
    opacity: 0;
    transform: translateY(40rpx) scale(0.92);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
.done-card__top { text-align: center; margin-bottom: 20rpx; }
.done-card__title {
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: #00ff88;
  margin-bottom: 8rpx;
}
.done-card__name {
  font-size: 36rpx;
  font-weight: 700;
  color: #f0f0f5;
}

.done-card__ring {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0 24rpx;
}
.done-ring {
  position: relative;
  width: 280rpx;
  height: 280rpx;
  margin-bottom: 12rpx;
}
.done-ring__bg {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 14rpx solid rgba(255, 255, 255, 0.06);
  box-sizing: border-box;
}
.done-ring__fill {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 14rpx solid transparent;
  border-top-color: #00ff88;
  border-right-color: #00e5ff;
  box-sizing: border-box;
  transform-origin: center;
  filter: drop-shadow(0 0 16rpx rgba(0, 255, 136, 0.6));
}
.done-ring__anim {
  animation: ringSpin 2.2s cubic-bezier(0.22, 1, 0.36, 1) both;
}
@keyframes ringSpin {
  from {
    transform: rotate(-180deg);
    opacity: 0;
  }
  to {
    transform: rotate(270deg);
    opacity: 1;
  }
}
.done-ring__text {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.done-ring__num {
  font-size: 88rpx;
  font-weight: 700;
  color: #00ff88;
  font-variant-numeric: tabular-nums;
  text-shadow: 0 0 40rpx rgba(0, 255, 136, 0.5);
  line-height: 1;
}
.done-ring__num--anim {
  animation: numRoll 1.6s cubic-bezier(0.22, 1, 0.36, 1) both;
}
@keyframes numRoll {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.done-ring__unit {
  font-size: 22rpx;
  color: #8b8fa3;
  letter-spacing: 4rpx;
  margin-top: 6rpx;
}
.done-card__method {
  font-size: 18rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  margin-top: 8rpx;
}
.done-card__method--work {
  color: #00ff88;
  background: rgba(0, 255, 136, 0.1);
  border: 1rpx solid rgba(0, 255, 136, 0.25);
}
.done-card__method--met {
  color: #00e5ff;
  background: rgba(0, 229, 255, 0.1);
  border: 1rpx solid rgba(0, 229, 255, 0.25);
}
.done-card__method--estimate {
  color: #8b8fa3;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.done-card__stats {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
  margin-bottom: 20rpx;
}
.done-stat {
  flex: 1;
  text-align: center;
}
.done-stat__num {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #f0f0f5;
  font-variant-numeric: tabular-nums;
  line-height: 1.1;
}
.done-stat__num--sm {
  font-size: 30rpx;
}
.done-stat__label {
  display: block;
  font-size: 20rpx;
  color: #8b8fa3;
  margin-top: 4rpx;
  letter-spacing: 2rpx;
}
.done-stat__divider {
  width: 2rpx;
  height: 60rpx;
  background: linear-gradient(180deg, transparent, rgba(255, 255, 255, 0.1), transparent);
}

.done-card__breakdown {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 12rpx 0 20rpx;
}
.done-bd {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 4rpx 8rpx;
}
.done-bd__label {
  font-size: 22rpx;
  color: #8b8fa3;
  letter-spacing: 1rpx;
}
.done-bd__val {
  font-size: 22rpx;
  color: #f0f0f5;
  font-variant-numeric: tabular-nums;
  font-weight: 500;
}

.done-card__hint {
  text-align: center;
  font-size: 20rpx;
  color: #4b5563;
  letter-spacing: 1rpx;
  padding-top: 12rpx;
}

/* ===== Session 总结 ===== */
.summary-mask {
  position: fixed;
  inset: 0;
  background: rgba(10, 14, 23, 0.9);
  backdrop-filter: blur(20rpx);
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  animation: maskFadeIn 0.3s ease both;
}
@keyframes maskFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
.summary-card {
  width: 100%;
  max-width: 680rpx;
  background: linear-gradient(160deg, #0d2818 0%, #0a1628 60%, #0e0a28 100%);
  border: 1rpx solid rgba(0, 255, 136, 0.25);
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.5), 0 0 80rpx rgba(0, 255, 136, 0.15);
  max-height: 85vh;
  overflow-y: auto;
}
.summary-card__title {
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #00ff88;
  text-shadow: 0 0 24rpx rgba(0, 255, 136, 0.4);
  margin-bottom: 8rpx;
}
.summary-card__plan {
  text-align: center;
  font-size: 24rpx;
  color: #8b8fa3;
  margin-bottom: 28rpx;
  letter-spacing: 1rpx;
}
.summary-card__stats {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  margin-bottom: 24rpx;
}
.summary-stat { text-align: center; }
.summary-stat__num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #f0f0f5;
  font-variant-numeric: tabular-nums;
  line-height: 1.1;
}
.summary-stat__label {
  display: block;
  font-size: 20rpx;
  color: #8b8fa3;
  margin-top: 4rpx;
  letter-spacing: 1rpx;
}
.summary-card__list {
  max-height: 360rpx;
  overflow-y: auto;
  margin-bottom: 24rpx;
}
.summary-ex {
  display: flex;
  align-items: center;
  padding: 14rpx 16rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  margin-bottom: 10rpx;
  gap: 14rpx;
}
.summary-ex__check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #00ff88;
  color: #0a0e17;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
  flex-shrink: 0;
}
.summary-ex__body { flex: 1; min-width: 0; }
.summary-ex__name {
  display: block;
  font-size: 24rpx;
  color: #f0f0f5;
  font-weight: 500;
  margin-bottom: 2rpx;
}
.summary-ex__meta {
  display: block;
  font-size: 20rpx;
  color: #8b8fa3;
  font-variant-numeric: tabular-nums;
}
.summary-card__btn {
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 999rpx;
  letter-spacing: 2rpx;
  transition: transform 0.15s;
}
.summary-card__btn:active { transform: scale(0.96); opacity: 0.85; }
.summary-card__actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.summary-card__btn--primary {
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  color: #0a0e17;
  box-shadow: 0 0 24rpx rgba(0, 255, 136, 0.35);
}
.summary-card__btn--ghost {
  background: rgba(0, 229, 255, 0.08);
  color: #00e5ff;
  border: 1rpx solid rgba(0, 229, 255, 0.3);
}

/* 海报画布（隐藏） */
.poster-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  opacity: 0;
  pointer-events: none;
}

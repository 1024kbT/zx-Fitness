.ex-card {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.ex-card:active {
  background: rgba(255, 255, 255, 0.07);
}

.ex-card__icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: rgba(0, 255, 136, 0.06);
  border: 1rpx solid rgba(0, 255, 136, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.ex-card__image {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  background: rgba(0, 255, 136, 0.04);
}

.ex-card__body {
  flex: 1;
  min-width: 0;
}

.ex-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #f0f0f5;
  margin-bottom: 8rpx;
}

.ex-card__meta {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.ex-card__muscle {
  font-size: 22rpx;
  color: #8b8fa3;
}

.ex-card__sub {
  font-size: 24rpx;
  color: #4b5563;
  font-variant-numeric: tabular-nums;
}

.ex-card__arrow {
  font-size: 40rpx;
  color: #4b5563;
  margin-left: 16rpx;
}
